# StudioLibrary (Media Library) — engine env. Copy needed vars into the repo's
# .env.local. These are SEPARATE from the app's Neon / fal / blob config.

# Local Docker Postgres + pgvector (docker-compose.yml). Never Neon.
DATABASE_URL_LIBRARY=postgresql://studio:studio@localhost:5433/studiolibrary

# Volume + encoder selection — the ONLY things that change for the Oslo switch.
# Phase 0 (Mac):   videotoolbox + the local test volume (defaults below).
# Oslo (A6000):    LIBRARY_ENCODER=nvenc, and add an SMB volume in lib/config.
LIBRARY_ENCODER=videotoolbox
# LIBRARY_LOCAL_ROOT=/Users/espenhorne/DEV/espenhorne/StudioCreation/studiolibrary/test-media
# LIBRARY_PROXY_ROOT=/Users/espenhorne/DEV/espenhorne/StudioCreation/studiolibrary/proxies

# Worker concurrency (video transcode is the heavy lane).
# LIBRARY_PROXY_CONCURRENCY=2

# Oslo-only hard guard: SMBVolume refuses to construct unless this is set, on
# the Oslo host, with the on-prem archive mounted READ-ONLY. Leave UNSET in dev.
# LIBRARY_ALLOW_SMB=1

# Local Whisper (faster-whisper) for transcription. Defaults to the repo venv
# (python3.11 + faster-whisper). On the A6000, set WHISPER_DEVICE=cuda.
# WHISPER_PYTHON=/Users/espenhorne/DEV/espenhorne/StudioCreation/studiolibrary/.venv/bin/python
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu
